{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (student or faculty)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["student", "faculty"], "description": "User role" },
        "name": { "type": "string", "description": "Display name" },
        "photoURL": { "type": "string", "description": "Profile picture URL" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Detailed student profile",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Student ID (12-digit)" },
        "name": { "type": "string" },
        "dob": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "course": { "type": "string" },
        "year": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Late"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "An academic assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Submitted", "Graded"] },
        "grade": { "type": "string" },
        "description": { "type": "string" },
        "instructions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "subject", "dueDate", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success"] }
      },
      "required": ["id", "title", "message", "date", "type"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User roles and basic info"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student profiles"
    },
    "/attendance/{recordId}": {
      "schema": "Attendance",
      "description": "Attendance logs"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Course assignments"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System-wide notifications"
    }
  }
}
