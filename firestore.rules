rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isFaculty() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty';
    }
    
    function isStudent() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty';
    }

    match /students/{studentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty';
    }

    match /attendance/{recordId} {
      allow read: if isFaculty() || (isStudent() && (request.auth.token.email == resource.data.studentEmail || request.auth.uid == resource.data.studentId));
      allow write: if isFaculty();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isFaculty();
      allow update: if isFaculty() || isStudent();
      allow delete: if isFaculty();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isFaculty();
    }
  }
}
